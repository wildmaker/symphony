#!/usr/bin/env python3
"""
cursor-symphony-bridge — Protocol adapter between Symphony's JSON-RPC
app-server interface and the Cursor CLI ACP (Agent Client Protocol).

Spawns ``agent acp`` as a long-lived subprocess and translates between
Symphony's app-server protocol and ACP's session-based JSON-RPC 2.0
protocol over stdio.

The bridge keeps the ACP process alive across turns so sessions persist,
streaming updates flow back, and tool-permission requests are handled
automatically.

Usage (from WORKFLOW.md agents section)::

    agents:
      cursor:
        command: cursor-symphony-bridge --model gpt-5.4

Supports ``--model`` flag or ``CURSOR_MODEL`` env var to select the
underlying LLM.  The flag takes precedence over the env var.
"""

from __future__ import annotations

import argparse
import json
import os
import signal
import subprocess
import sys
import threading
import time
import uuid


# ---------------------------------------------------------------------------
# Helpers — Symphony (upstream) communication
# ---------------------------------------------------------------------------

def send_response(payload: dict) -> None:
    """Write a JSON-RPC response/notification to stdout (Symphony side)."""
    line = json.dumps(payload, separators=(",", ":"))
    sys.stdout.write(line + "\n")
    sys.stdout.flush()


def log(message: str) -> None:
    """Write a diagnostic message to stderr."""
    sys.stderr.write(f"[cursor-bridge] {message}\n")
    sys.stderr.flush()


_session_log_file = None


def session_log(message: str) -> None:
    """Append a human-readable line to the session activity log."""
    global _session_log_file
    if _session_log_file is None:
        log_dir = os.path.expanduser("~/.cache/symphony-logs")
        os.makedirs(log_dir, exist_ok=True)
        _session_log_file = open(
            os.path.join(log_dir, f"bridge-{os.getpid()}.log"), "a"
        )
    ts = time.strftime("%H:%M:%S")
    _session_log_file.write(f"[{ts}] {message}\n")
    _session_log_file.flush()


def _resolve_mcp_server_path() -> str:
    """Locate symphony-linear-mcp next to this bridge script."""
    bridge_dir = os.path.dirname(os.path.abspath(__file__))
    candidate = os.path.join(bridge_dir, "symphony-linear-mcp")
    if os.path.isfile(candidate):
        return candidate
    # Fallback: assume it's on PATH
    return "symphony-linear-mcp"


# ---------------------------------------------------------------------------
# ACPClient — manages the ``agent acp`` child process
# ---------------------------------------------------------------------------

class ACPClient:
    """Manages a long-lived ``agent acp`` child process and speaks the ACP
    JSON-RPC 2.0 protocol over its stdio streams.

    Communication model:
    * A background *reader* thread continuously reads newline-delimited JSON
      from the ACP process's stdout.
    * Responses (messages with an ``id`` matching a pending request) are
      routed to the waiting caller via a per-request ``threading.Event``.
    * Notifications (``session/update``) are logged for observability.
    * Requests from ACP (``session/request_permission``) are auto-approved.
    * Cursor extension methods are handled gracefully.
    """

    def __init__(self, *, model: str | None = None) -> None:
        self.process: subprocess.Popen | None = None
        self._model = model
        self._next_id: int = 1
        self._lock = threading.Lock()
        self._pending: dict[int, dict] = {}
        self._reader_thread: threading.Thread | None = None
        self._alive = False

    # -- lifecycle ----------------------------------------------------------

    def start(self) -> None:
        """Spawn the ``agent acp`` process."""
        cmd: list[str] = ["agent"]
        api_key = os.environ.get("CURSOR_API_KEY")
        if api_key:
            cmd += ["--api-key", api_key]
        if self._model:
            cmd += ["--model", self._model]
        cmd.append("acp")

        try:
            self.process = subprocess.Popen(
                cmd,
                stdin=subprocess.PIPE,
                stdout=subprocess.PIPE,
                stderr=subprocess.DEVNULL,
                text=True,
            )
        except FileNotFoundError:
            raise RuntimeError(
                "agent CLI not found on PATH. Install Cursor CLI and ensure "
                "'agent' is available."
            )

        self._alive = True
        self._reader_thread = threading.Thread(
            target=self._read_loop, daemon=True
        )
        self._reader_thread.start()

    def stop(self) -> None:
        """Terminate the ACP child process."""
        self._alive = False
        if self.process and self.process.poll() is None:
            try:
                self.process.terminate()
                self.process.wait(timeout=5)
            except Exception:
                try:
                    self.process.kill()
                except Exception:
                    pass

    @property
    def is_alive(self) -> bool:
        return (
            self._alive
            and self.process is not None
            and self.process.poll() is None
        )

    # -- ACP protocol helpers -----------------------------------------------

    def initialize(self) -> dict:
        """Perform the ACP ``initialize`` handshake."""
        return self._send_request("initialize", {
            "protocolVersion": 1,
            "clientCapabilities": {
                "fs": {"readTextFile": False, "writeTextFile": False},
                "terminal": False,
            },
            "clientInfo": {
                "name": "symphony-cursor-bridge",
                "title": "Symphony Cursor Bridge",
                "version": "1.0.0",
            },
        })

    def authenticate(self) -> dict:
        """Perform ACP ``authenticate`` with cursor_login method."""
        return self._send_request("authenticate", {
            "methodId": "cursor_login",
        })

    def new_session(self, cwd: str, mcp_servers: list | None = None) -> str:
        """Create a new ACP session.  Returns the ``sessionId``."""
        params: dict = {
            "cwd": cwd,
            "mcpServers": mcp_servers or [],
        }
        result = self._send_request("session/new", params, timeout=120)
        session_id = result.get("sessionId") if isinstance(result, dict) else None
        if not session_id:
            raise RuntimeError(f"session/new did not return a sessionId: {result!r}")
        return session_id

    def prompt(self, session_id: str, text: str, *, timeout: int = 3600) -> dict:
        """Send ``session/prompt`` and block until the prompt completes."""
        return self._send_request(
            "session/prompt",
            {
                "sessionId": session_id,
                "prompt": [{"type": "text", "text": text}],
            },
            timeout=timeout,
        )

    # -- low-level transport ------------------------------------------------

    def _allocate_id(self) -> int:
        with self._lock:
            rid = self._next_id
            self._next_id += 1
        return rid

    def _send_request(
        self, method: str, params: dict, *, timeout: int = 60
    ) -> dict:
        """Send a JSON-RPC request and wait synchronously for the response."""
        if not self.is_alive:
            raise RuntimeError("ACP process is not running")

        rid = self._allocate_id()
        entry: dict = {"event": threading.Event(), "result": None, "error": None}
        with self._lock:
            self._pending[rid] = entry

        message = {
            "jsonrpc": "2.0",
            "id": rid,
            "method": method,
            "params": params,
        }
        self._write(message)

        if not entry["event"].wait(timeout=timeout):
            with self._lock:
                self._pending.pop(rid, None)
            raise RuntimeError(
                f"Timeout waiting for ACP response to {method} (id={rid})"
            )

        with self._lock:
            self._pending.pop(rid, None)

        if entry["error"] is not None:
            raise RuntimeError(
                f"ACP error for {method}: {entry['error']!r}"
            )

        return entry["result"]

    def _write(self, message: dict) -> None:
        """Write a single newline-delimited JSON-RPC message to ACP stdin."""
        if self.process and self.process.stdin:
            line = json.dumps(message, separators=(",", ":")) + "\n"
            try:
                self.process.stdin.write(line)
                self.process.stdin.flush()
            except (BrokenPipeError, OSError) as exc:
                log(f"Failed to write to ACP stdin: {exc}")
                self._alive = False

    def _respond(self, request_id, result: dict) -> None:
        """Send a JSON-RPC response back to ACP."""
        self._write({"jsonrpc": "2.0", "id": request_id, "result": result})

    # -- background reader --------------------------------------------------

    def _read_loop(self) -> None:
        """Continuously read lines from the ACP process stdout and dispatch."""
        assert self.process is not None
        assert self.process.stdout is not None

        try:
            for raw_line in self.process.stdout:
                line = raw_line.strip()
                if not line:
                    continue
                try:
                    msg = json.loads(line)
                except json.JSONDecodeError:
                    log(f"Non-JSON from ACP: {line[:200]}")
                    continue

                self._dispatch_acp_message(msg)
        except Exception as exc:
            log(f"ACP reader thread error: {exc}")
        finally:
            self._alive = False
            with self._lock:
                for entry in self._pending.values():
                    if entry["error"] is None and entry["result"] is None:
                        entry["error"] = "ACP process exited"
                    entry["event"].set()

    def _dispatch_acp_message(self, msg: dict) -> None:
        """Route an incoming ACP message to the right handler."""

        msg_id = msg.get("id")
        if msg_id is not None and ("result" in msg or "error" in msg):
            with self._lock:
                entry = self._pending.get(msg_id)
            if entry:
                if "error" in msg:
                    entry["error"] = msg["error"]
                else:
                    entry["result"] = msg.get("result", {})
                entry["event"].set()
            return

        method = msg.get("method")

        if method == "session/request_permission" and msg_id is not None:
            session_log(f"  [PERMISSION] auto-approving: {json.dumps(msg.get('params', {}), ensure_ascii=False)[:300]}")
            self._respond(msg_id, {
                "outcome": {
                    "outcome": "selected",
                    "optionId": "allow-always",
                },
            })
            return

        if method == "session/update":
            _log_session_update(msg)
            return

        # Cursor extension methods — respond with empty result to unblock
        if method and method.startswith("cursor/") and msg_id is not None:
            session_log(f"  [CURSOR_EXT] {method}")
            self._respond(msg_id, {})
            return

        if method:
            log(f"Unhandled ACP method: {method}")
            if msg_id is not None:
                self._respond(msg_id, {})


# ---------------------------------------------------------------------------
# Session update logging
# ---------------------------------------------------------------------------

_update_count = 0


def _log_session_update(msg: dict) -> None:
    """Log session/update notifications using ACP sessionUpdate schema."""
    global _update_count
    params = msg.get("params", {})
    update = params.get("update", {})
    kind = update.get("sessionUpdate", "")

    _update_count += 1
    if _update_count <= 10:
        raw = json.dumps(params, ensure_ascii=False, default=str)
        session_log(f"  [RAW#{_update_count}] {raw[:2000]}")

    if kind == "agent_message_chunk":
        content = update.get("content", {})
        text = content.get("text", "") if isinstance(content, dict) else ""
        if text:
            for line in text.strip().splitlines():
                session_log(f"  [AGENT] {line}")

    elif kind == "plan":
        entries = update.get("entries", [])
        session_log(f"  [PLAN] {len(entries)} entries")
        for e in entries[:10]:
            st = e.get("status", "?")
            txt = e.get("content", "")[:120]
            session_log(f"    [{st}] {txt}")

    elif kind == "tool_call":
        title = update.get("title", "")
        status = update.get("status", "")
        tool_kind = update.get("kind", "")
        call_id = update.get("toolCallId", "")
        session_log(f"  [TOOL] {title} ({tool_kind}) -> {status} [{call_id}]")

    elif kind == "tool_call_update":
        tool_id = update.get("toolCallId", "")
        status = update.get("status", "")
        content_items = update.get("content", [])
        text = ""
        if isinstance(content_items, list):
            for ci in content_items:
                c = ci.get("content", {}) if isinstance(ci, dict) else {}
                t = c.get("text", "") if isinstance(c, dict) else ""
                if t:
                    text = t[:500]
                    break
        if text:
            session_log(f"  [TOOL_RESULT] {tool_id} {status}: {text}")
        else:
            session_log(f"  [TOOL_UPDATE] {tool_id} -> {status}")

    elif kind == "user_message_chunk":
        pass

    elif kind:
        raw_snippet = json.dumps(update, ensure_ascii=False, default=str)[:300]
        session_log(f"  [{kind}] {raw_snippet}")


# ---------------------------------------------------------------------------
# Bridge — translates Symphony app-server ↔ ACP
# ---------------------------------------------------------------------------

class Bridge:
    """Main bridge that reads Symphony app-server JSON-RPC from stdin and
    translates to ACP calls on the ``ACPClient``."""

    def __init__(self, *, model: str | None = None) -> None:
        self.acp = ACPClient(model=model)
        self.thread_sessions: dict[str, str] = {}
        self._mcp_server_path = _resolve_mcp_server_path()

    def start(self) -> None:
        """Start the ACP child process and perform the handshake."""
        self.acp.start()
        try:
            init_result = self.acp.initialize()
            session_log(f"[INIT] initialize result: {json.dumps(init_result, ensure_ascii=False, default=str)[:500]}")
        except Exception as exc:
            log(f"ACP initialization failed: {exc}")
            self.acp.stop()
            raise

        try:
            auth_result = self.acp.authenticate()
            session_log(f"[INIT] authenticate result: {json.dumps(auth_result, ensure_ascii=False, default=str)[:500]}")
        except Exception as exc:
            log(f"ACP authenticate failed (non-fatal, may already be logged in): {exc}")

    def stop(self) -> None:
        self.acp.stop()

    def _build_mcp_servers(self) -> list:
        """Build MCP server config for injection into ACP sessions."""
        servers = []

        if os.environ.get("LINEAR_API_KEY"):
            env_vars = [
                {"name": "LINEAR_API_KEY", "value": os.environ["LINEAR_API_KEY"]},
            ]
            servers.append({
                "name": "symphony-linear",
                "command": self._mcp_server_path,
                "args": [],
                "env": env_vars,
            })
            session_log(f"[MCP] will inject symphony-linear from {self._mcp_server_path}")
        else:
            session_log("[MCP] LINEAR_API_KEY not set, skipping linear MCP server")

        return servers

    # -- Symphony message handlers -----------------------------------------

    def handle_initialize(self, msg: dict) -> None:
        """Respond to Symphony's ``initialize`` handshake."""
        send_response({"id": msg["id"], "result": {}})

    def handle_thread_start(self, msg: dict) -> None:
        """Map Symphony ``thread/start`` → ACP ``session/new``."""
        params = msg.get("params", {})
        cwd = params.get("cwd", os.getcwd())

        mcp_servers = self._build_mcp_servers()

        try:
            session_id = self.acp.new_session(cwd, mcp_servers)
        except Exception as exc:
            session_log(f"[SESSION] new_session FAILED: {exc}")
            send_response({
                "id": msg["id"],
                "error": {
                    "code": -32000,
                    "message": f"Failed to create ACP session: {exc}",
                },
            })
            return

        thread_id = f"cursor-thread-{uuid.uuid4().hex[:12]}"
        self.thread_sessions[thread_id] = session_id
        session_log(f"[SESSION] created thread={thread_id} acp_session={session_id} cwd={cwd} mcp_count={len(mcp_servers)}")

        send_response({
            "id": msg["id"],
            "result": {"thread": {"id": thread_id}},
        })

    def handle_turn_start(self, msg: dict) -> None:
        """Map Symphony ``turn/start`` → ACP ``session/prompt``."""
        params = msg.get("params", {})
        turn_id = f"cursor-turn-{uuid.uuid4().hex[:12]}"

        prompt = ""
        for item in params.get("input", []):
            if isinstance(item, dict) and item.get("type") == "text":
                prompt += item.get("text", "")

        thread_id = params.get("threadId")
        session_id = self.thread_sessions.get(thread_id) if thread_id else None

        if not session_id:
            cwd = params.get("cwd", os.getcwd())
            mcp_servers = self._build_mcp_servers()
            try:
                session_id = self.acp.new_session(cwd, mcp_servers)
                if thread_id:
                    self.thread_sessions[thread_id] = session_id
            except Exception as exc:
                send_response({"id": msg["id"], "result": {"turn": {"id": turn_id}}})
                send_response({
                    "method": "turn/failed",
                    "params": {"error": f"Failed to create ACP session: {exc}"},
                })
                return

        send_response({
            "id": msg["id"],
            "result": {"turn": {"id": turn_id}},
        })

        session_log(f"[TURN] start turn={turn_id} prompt={prompt[:200]}...")

        try:
            if not self.acp.is_alive:
                self._restart_acp()

            result = self.acp.prompt(session_id, prompt, timeout=3600)

            stop_reason = result.get("stopReason", "") if isinstance(result, dict) else ""
            session_log(f"[TURN] finished turn={turn_id} stopReason={stop_reason}")
            if stop_reason == "end_turn":
                send_response({"method": "turn/completed"})
            elif stop_reason == "cancelled":
                send_response({
                    "method": "turn/failed",
                    "params": {"error": "ACP session was cancelled"},
                })
            elif stop_reason == "error":
                error_detail = result.get("error", "unknown error") if isinstance(result, dict) else "unknown error"
                send_response({
                    "method": "turn/failed",
                    "params": {"error": f"ACP session error: {error_detail}"},
                })
            else:
                send_response({"method": "turn/completed"})

        except Exception as exc:
            session_log(f"[TURN] error turn={turn_id}: {exc}")
            send_response({
                "method": "turn/failed",
                "params": {"error": f"ACP prompt failed: {exc}"},
            })

    def _restart_acp(self) -> None:
        """Attempt to restart the ACP process after a crash."""
        log("ACP process died — attempting restart")
        self.acp.stop()
        self.thread_sessions.clear()
        try:
            self.acp.start()
            self.acp.initialize()
            try:
                self.acp.authenticate()
            except Exception as exc:
                log(f"ACP authenticate failed on restart (non-fatal): {exc}")
            log("ACP process restarted successfully")
        except Exception as exc:
            log(f"ACP restart failed: {exc}")
            raise

    # -- main loop ----------------------------------------------------------

    def run(self) -> None:
        """Read JSON-RPC lines from stdin (Symphony) and dispatch."""
        for raw_line in sys.stdin:
            line = raw_line.strip()
            if not line:
                continue

            try:
                msg = json.loads(line)
            except json.JSONDecodeError:
                continue

            method = msg.get("method")

            if method == "initialize":
                self.handle_initialize(msg)
            elif method == "initialized":
                pass
            elif method == "thread/start":
                self.handle_thread_start(msg)
            elif method == "turn/start":
                self.handle_turn_start(msg)
            else:
                if "id" in msg:
                    send_response({
                        "id": msg["id"],
                        "error": {
                            "code": -32601,
                            "message": f"Method not found: {method}",
                        },
                    })


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def main() -> None:
    parser = argparse.ArgumentParser(
        description="Symphony ↔ Cursor ACP protocol bridge",
    )
    parser.add_argument(
        "--model",
        default=os.environ.get("CURSOR_MODEL"),
        help="Model to pass to the Cursor agent CLI (overrides CURSOR_MODEL env var)",
    )
    args = parser.parse_args()

    model = args.model
    if model:
        log(f"Using model: {model}")

    bridge = Bridge(model=model)

    def _shutdown(signum, frame):
        bridge.stop()
        sys.exit(0)

    signal.signal(signal.SIGTERM, _shutdown)

    try:
        bridge.start()
    except Exception as exc:
        log(f"Fatal: failed to start ACP bridge: {exc}")

    try:
        bridge.run()
    except KeyboardInterrupt:
        pass
    finally:
        bridge.stop()


if __name__ == "__main__":
    main()
